.venv/
__pycache__/
*.pyc
.env
data/
*.db
*.db-wal
*.db-shm
*.lock
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
*.egg-info/

# Phase 2: bootstrap-created symlink (regenerated on daemon start).
.claude/skills

# Spike probes generate machine-readable reports; keep source files, skip reports.
spikes/sdk_probe*_report.json

# Phase 3: skills installed at runtime via marketplace/installer. The two
# canonical skills that ARE tracked are explicitly whitelisted below.
skills/*
!skills/ping/
!skills/skill-installer/
!skills/memory/

# Same for runtime-installed tools/<name>/ (bundles that ship a top-level
# tools/ subdir end up here after atomic_install). Only `ping` and
# `skill-installer` (phase 3) and `memory` (phase 4) are tracked.
tools/*
!tools/ping/
!tools/skill-installer/
!tools/memory/
