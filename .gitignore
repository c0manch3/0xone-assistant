.venv/
__pycache__/
*.pyc
.env
.env.*
# Whitelist .env.example template files — they MUST be tracked so new
# checkouts can `cp .env.example .env`. The `.env.*` glob above would
# otherwise match `.env.example` (verified via `git check-ignore -v`).
!**/.env.example
!.env.example
secrets.env
**/secrets.env
data/
*.db
*.db-wal
*.db-shm
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
*.egg-info/

# Phase 5d Docker compose owner-local override (TAG pin lives here).
deploy/docker/.env

# Phase 2: .claude/ is the per-project CLI dir. `skills` is a generated
# symlink (bootstrap rewrites it on every start); settings files may be
# created manually by the owner and should never be committed. Harness
# may also drop runtime artefacts (scheduled_tasks.lock, etc.).
.claude/

# Spike scripts live in-repo; their generated reports are throwaway.
plan/phase2/spikes/*.json

# Runtime-installed skills (via installer tool or auto-bootstrap).
# Only skills shipped with repo: ping, skill-installer.
skills/*
!skills/.gitkeep
!skills/ping/
!skills/ping/**
!skills/skill-installer/
!skills/skill-installer/**
!skills/memory/
!skills/memory/**
!skills/scheduler/
!skills/scheduler/**

# Tools installed with skills (only ping is repo-shipped).
tools/*
!tools/.gitkeep
!tools/ping/
!tools/ping/**

# Phase 4 memory subsystem runtime artefacts.
memory-index.db
memory-index.db-wal
memory-index.db-shm
memory-index.db.lock
memory-audit.log

# Phase 5 scheduler runtime artefacts.
scheduler-audit.log
.last_clean_exit
.daemon.pid
