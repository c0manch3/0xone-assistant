# 0xone-assistant — production environment template.
#
# Usage on the deploy host:
#   cp .env.production.example .env
#   # fill in every <set-...> placeholder
#   docker compose up -d --build
#
# Phase-8 vault auto-commit is DISABLED out of the box. To enable it later,
# follow docs/ops/github-setup.md (issue a deploy key for the vault repo,
# mount it into the container, then flip GH_AUTO_COMMIT_ENABLED=true and
# set the remaining GH_* vars below).

# ─── Required ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<set-real-token>
OWNER_CHAT_ID=177309887

# ─── Claude (OAuth via bind-mounted ~/.claude; do NOT set ANTHROPIC_API_KEY) ─
CLAUDE_TIMEOUT=120
CLAUDE_MAX_CONCURRENT=3
CLAUDE_MAX_TURNS=10

# ─── Data ────────────────────────────────────────────────────────────────
# Maps to the `./data` bind-mount from docker-compose.yml.
# Honored by both the daemon AND every tools/* helper — persistence is
# guaranteed only while this path points at a bind mount; a value that
# resolves inside the container overlay FS is lost on --force-recreate.
ASSISTANT_DATA_DIR=/app/data
# Vault lives at $ASSISTANT_DATA_DIR/vault/ and is auto-bootstrapped as its
# own git repo on first push (see docs/ops/github-setup.md).

# ─── Memory (phase 4) ────────────────────────────────────────────────────
# Defaults are fine; override only if the memory tool misbehaves.

# ─── Scheduler (phase 5) ─────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Moscow

# ─── Media (phase 7) ─────────────────────────────────────────────────────
# Defaults OK: 14d inbox retention, 7d outbox retention, 2 GB total cap.

# ─── GitHub / vault auto-commit (phase 8) — DISABLED initially ───────────
GH_AUTO_COMMIT_ENABLED=false
# GH_VAULT_REMOTE_URL=git@github.com:vaultbot-owner/vault-backup.git
# GH_VAULT_SSH_KEY_PATH=/root/.ssh/id_vault
# GH_ALLOWED_REPOS=vaultbot-owner/vault-backup
# GH_AUTO_COMMIT_TZ=Europe/Moscow

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=console    # phase 9 will enable a "json" option for shippers
