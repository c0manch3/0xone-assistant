# Copy this file to deploy/docker/.env and edit. Compose reads it
# automatically when invoked from this directory.
#
# Pin to a specific image tag for reproducible deploys:
#   TAG=phase5d           release tag, never auto-pruned
#   TAG=phase5d-rc1       release-candidate tag
#   TAG=sha-abc1234       CI-generated short SHA, retained 30 days
#
# DO NOT use TAG=latest in production — compose forces an explicit pin.
#
# Uncomment AFTER the first CI push lands a tag in GHCR; otherwise
# `docker compose pull` returns 404 manifest-unknown. To check what's
# available:
#   curl -s https://ghcr.io/v2/c0manch3/0xone-assistant/tags/list \
#     -H "Authorization: Bearer $(echo $GH_TOKEN | base64)" | jq .
# TAG=phase5d-rc1
