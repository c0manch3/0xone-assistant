# Phase-2 .env template.
#
# Post-migration location (N6): ~/.config/0xone-assistant/.env
# Fallback for development: ./.env (this file).
# Pydantic Settings checks the XDG path first, then the CWD file.
#
# Auth model: OAuth via ~/.claude/ (the CLI session). We do NOT accept
# ANTHROPIC_API_KEY here — the bridge rejects API-key auth entirely.

# -- Telegram --
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=

# -- Observability --
LOG_LEVEL=INFO

# -- Claude bridge knobs (all optional; defaults baked into ClaudeSettings) --
# CLAUDE_TIMEOUT=300           # seconds per turn
# CLAUDE_MAX_TURNS=20          # SDK-side per-query turn cap
# CLAUDE_MAX_CONCURRENT=2      # simultaneous bridge calls
# CLAUDE_HISTORY_LIMIT=20      # turn-count (B6: turns, not rows)
# CLAUDE_THINKING_BUDGET=0     # 0 = off; >0 enables max_thinking_tokens
# CLAUDE_EFFORT=medium         # passed only when thinking_budget > 0

# -- Phase 4 memory (optional — defaults to XDG) --
# MEMORY_VAULT_DIR=/path/to/existing/Obsidian/vault
# MEMORY_INDEX_DB_PATH=/path/to/memory-index.db
# MEMORY_MAX_BODY_BYTES=1048576
# MEMORY_ALLOW_LARGE_REINDEX=0
