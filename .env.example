# Phase-2 .env template.
#
# Post-migration location (N6): ~/.config/0xone-assistant/.env
# Fallback for development: ./.env (this file).
# Pydantic Settings checks the XDG path first, then the CWD file.
#
# Auth model: OAuth via ~/.claude/ (the CLI session). We do NOT accept
# ANTHROPIC_API_KEY here — the bridge rejects API-key auth entirely.

# -- Telegram --
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=

# -- Observability --
LOG_LEVEL=INFO

# -- Claude bridge knobs (all optional; defaults baked into ClaudeSettings) --
# CLAUDE_TIMEOUT=300           # seconds per turn
# CLAUDE_MAX_TURNS=20          # SDK-side per-query turn cap
# CLAUDE_MAX_CONCURRENT=2      # simultaneous bridge calls
# CLAUDE_HISTORY_LIMIT=20      # turn-count (B6: turns, not rows)
# CLAUDE_THINKING_BUDGET=0     # 0 = off; >0 enables max_thinking_tokens
# CLAUDE_EFFORT=medium         # passed only when thinking_budget > 0

# -- Phase 4 memory (optional — defaults to XDG) --
# MEMORY_VAULT_DIR=/path/to/existing/Obsidian/vault
# MEMORY_INDEX_DB_PATH=/path/to/memory-index.db
# MEMORY_MAX_BODY_BYTES=1048576
# MEMORY_ALLOW_LARGE_REINDEX=0

# -- Phase 5 scheduler (all optional; defaults baked into SchedulerSettings) --
# SCHEDULER_ENABLED=true               # disable to turn off loop + dispatcher; @tool handlers stay accessible
# SCHEDULER_TICK_INTERVAL_S=15         # how often the producer loop wakes to scan schedules
# SCHEDULER_TZ_DEFAULT=UTC             # default IANA tz for schedule_add when caller omits tz
# SCHEDULER_CATCHUP_WINDOW_S=3600      # max seconds of missed-work replay on boot / wake
# SCHEDULER_DEAD_ATTEMPTS_THRESHOLD=5  # revert_to_pending count that triggers dead-letter + notify
# SCHEDULER_SENT_REVERT_TIMEOUT_S=360  # INVARIANT: MUST be > CLAUDE_TIMEOUT (default 300); violation is log-warned at runtime, not fatal
# SCHEDULER_DISPATCHER_QUEUE_SIZE=64   # asyncio queue maxsize between loop and dispatcher
# SCHEDULER_MAX_SCHEDULES=64           # cap on enabled schedules (recursion-bomb guard)
# SCHEDULER_MISSED_NOTIFY_COOLDOWN_S=86400  # reserved for recap rate-limit (phase 5c)
# SCHEDULER_MIN_RECAP_THRESHOLD=2      # catchup_missed count that fires the recap notify
# SCHEDULER_CLEAN_EXIT_WINDOW_S=120    # .last_clean_exit mtime age classifying boot as clean-deploy
# SCHEDULER_RECLAIM_OLDER_THAN_S=30    # reclaim_pending_not_queued age threshold; must be > tick_interval_s
