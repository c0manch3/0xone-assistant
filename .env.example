TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=
LOG_LEVEL=INFO

# Production .env lives at ~/.config/0xone-assistant/.env (XDG_CONFIG_HOME/0xone-assistant/.env).
# ./.env (this repo) is a dev fallback; pydantic-settings prefers the XDG path.
#
# Auth: Claude Code SDK uses OAuth via the `claude` CLI (`~/.claude/`).
# DO NOT set ANTHROPIC_API_KEY here — it is intentionally unused.

CLAUDE_TIMEOUT=300
CLAUDE_MAX_TURNS=20
CLAUDE_MAX_CONCURRENT=2
CLAUDE_HISTORY_LIMIT=20
CLAUDE_THINKING_BUDGET=0
CLAUDE_EFFORT=medium
