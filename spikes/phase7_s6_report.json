  "Bot_download_file_signature": "(self, file_path: 'str | pathlib.Path', destination: 'BinaryIO | pathlib.Path | str | None' = None, timeout: 'int' = 30, chunk_size: 'int' = 65536, seek: 'bool' = True) -> 'BinaryIO | None'",
  "case_a_None_size_small_payload": {
