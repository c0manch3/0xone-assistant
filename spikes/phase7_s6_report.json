  },
  "case_c_known_oversize_preflight": {
    "allowed": false,
    "reason": "file_size 5000000 > cap 102400"
  },
  "case_d_known_in_cap": {
    "allowed": true,
    "bytes": 4096
  },
  "verdict": "PASS",
  "telegram_bot_api_max_bytes_for_getFile": 20971520,
  "recommendation": "media/download.py MUST: (1) check file.file_size if set AND reject >cap, (2) stream via a SizeCappedWriter wrapper so None-sized attachments (video_note, voice in some aiogram versions) abort mid-download, (3) set media-caps BELOW Telegram's 20MB hard limit (voice 15MB, photo 10MB, doc 20MB = at-ceiling)."
}